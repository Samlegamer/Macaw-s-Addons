{
	"schemaVersion": 1,
    "id": "${archives_base_name}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
      "${mod_authors}"
    ],
    "contact": {
      "homepage": "${mod_project_url}",
      "sources": "${mod_issue_tracker}"
    },
    "license": "${mod_license}",
    "icon": "logo.png",
    "environment": "*",
    "entrypoints": {
      "main": [
        "${mod_init}"
      ],
      "client": [
        "${mod_init_client}"
      ],
      "fabric-datagen": [
        "${mod_init_datagen}"
      ]
    },
    "depends": {
          "fabricloader": ">=0.19.2",
          "minecraft": "~1.21.1",
          "java": ">=21",
          "fabric-api": "*",
          "addonslib": ">=1.21.1-1.13"
      },
      "suggests": {
          "another-mod": "*"
      }
}