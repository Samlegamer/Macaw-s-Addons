{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
        "${mod_authors}"
    ],
    "contact": {
        "homepage": "${website_link}",
        "sources": "${issues_link}"
    },
    "license": "${mod_license}",
    "icon": "logo.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "${mod_init}"
        ],
        "client": [
            "${mod_init_client}"
        ],
        "fabric-datagen": [
            "${mod_init_datagen}"
        ]
    },
    "depends": {
        "fabricloader": ">=0.14",
        "fabric": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=17",
        "mysticsbiomes": "*",
        "addonslib": ">=${addonslib_last_version_fabric}"
    },
    "suggests": {
        "another-mod": "*"
    }
}
  